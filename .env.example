BACKEND=yolo_psp
DB_URL=postgresql+asyncpg://postgres:1234@localhost:5432/vivarium
YOLO_WEIGHTS=models/yolo/best.pt
YOLOX_EXP=exps/yolox_vivarium_tiny.py
SSD_WEIGHTS=models/ssd/ssd_mobilenet.onnx
CAMERA_RTSP_URL=rtsp://camera-ip/stream
ALERT_WEBHOOK_URL=https://your-webhook-url
YOLO_DEVICE=cuda
PSP_WATER_WEIGHTS=runs/pspnet/water/best.pth
PSP_FOOD_WEIGHTS=runs/pspnet/food_v2/best.pth
PSP_BACKBONE=resnet50
YOLO_CONF_THRESHOLD=0.30
BEDDING_CLIP_DIRTY_THRESHOLD=0.55   # lower = more sensitive to soiling
BEDDING_USE_CLIP=true
CLIP_LOCAL_PATH=models/clip/clip-vit-base-patch32